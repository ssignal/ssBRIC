[
  {
    "category": "Motion",
    "action": "motion/start_motion",
    "description": "Q9 motion ID를 지정해 motion을 시작한다.",
    "parameters": [
      {
        "name": "motion_id",
        "type": "string",
        "description": "ID from /api/action/motion/list. The app resolves task_type and motion/legacy/preset target from this ID.",
        "options": [],
        "min": null,
        "max": null
      },
      {
        "name": "blocking_type",
        "type": "string",
        "description": "Scheduler blocking mode while the motion is running.",
        "options": [
          {
            "value": "NONE",
            "description": "Resolve on completion."
          },
          {
            "value": "SOFT",
            "description": "Soft blocking until completion."
          },
          {
            "value": "HARD",
            "description": "Hard blocking until completion."
          },
          {
            "value": "LOOP",
            "description": "Re-execute the motion until released."
          },
          {
            "value": "WAIT",
            "description": "Keep waiting after completion until release."
          }
        ],
        "min": null,
        "max": null
      },
      {
        "name": "duration_ms",
        "type": "integer",
        "description": "Optional extra timeout. If set, stop_motion is triggered after this many milliseconds.",
        "options": [],
        "min": 0,
        "max": null
      }
    ]
  },
